{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "flirtual-app-redirect",
	"main": "src/index.js",
	"compatibility_date": "2026-07-17",
	"workers_dev": false,
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "flirtual.app", "custom_domain": true },
		{ "pattern": "www.flirtual.app", "custom_domain": true }
	]
}
