# Environment variables used by the frontend application.
# Used only for local development, production values are expected to be set by the host environment.

# Cloudflare Turnstile credentials, used for registration captcha.
# See https://developers.cloudflare.com/turnstile/

## Required to authenticate requests to the Turnstile API.
## Must match the "TURNSTILE_APP_ID" value in apps/api/.env.local.
## Expected format: "0xabcdefghijklmnopqrstuv"
export VITE_TURNSTILE_SITE_KEY="3x00000000000000000000FF"

# Talk.js credentials, used for chat.
# See https://talkjs.com/dashboard/

## Required to authenticate with the Talk.js API.
## Must match the "TALKJS_APP_ID" value in apps/api/.env.local.
## Expected format: "abcdefgh"
export VITE_TALKJS_APP_ID=""

# Chargebee subdomain, used for hosted checkout/portal.
export VITE_CHARGEBEE_NAMESPACE=""

# RevenueCat API keys, used for Apple and Google payments.
# See https://app.revenuecat.com/

## Required to authenticate with the RevenueCat API.
## Expected format: "platform_abcdefghijklmnopqrstuvwxyzz"
export VITE_RC_APPL_PUBLIC_KEY=""
export VITE_RC_GOOG_PUBLIC_KEY=""

# Sign In with Apple service ID.
VITE_APPLE_SIGNIN_SERVICE_ID=""

# Google OAuth web and iOS client IDs, used for Google sign-in.
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_IOS_CLIENT_ID=""

# Sentry credentials, used for error reporting.
# See https://sentry.io/

## Required to authenticate with the Sentry API.
export SENTRY_ORG=""
export SENTRY_PROJECT=""

## Where we should send errors to, must be a valid Sentry DSN.
export VITE_SENTRY_DSN=""

export VITE_SENTRY_ORGANIZATION=""
export VITE_SENTRY_PROJECT_ID=""

## Trace sample rate (0.0–1.0). Defaults to 0.1 in production builds, 0 in dev.
export VITE_SENTRY_TRACES=""

## Enable Sentry Logs (1 to enable). Defaults to 1 in production builds, 0 in dev.
export VITE_SENTRY_LOGS=""

## The report URL for Content Security Policy violations.
export VITE_SENTRY_REPORT_TO=""

# PostHog credentials, used for analytics.
# See https://posthog.com/
export VITE_POSTHOG_KEY=""
export VITE_POSTHOG_HOST=""

# Cloudflare
# See https://developers.cloudflare.com/web-analytics/
export VITE_CLOUDFLARE_BEACON_ID=""
export CLOUDFLARE_INTERNAL_IDENTIFIER=""

# Freshworks credentials, used for support.
# See https://developers.freshdesk.com/widget-api/

## Required to authenticate with the Freshworks API.
export VITE_FRESHWORKS_WIDGET_ID=73000002566

# Profile picture bucket URLs.
export VITE_BUCKET_CONTENT_ORIGIN=""
export VITE_BUCKET_UPLOADS_ORIGIN=""
export VITE_BUCKET_UPLOADS_SIGNED_ORIGIN=""

# .well-known files.
export VITE_ASSETLINKS_JSON=""
export VITE_APPLE_APP_SITE_ASSOCIATION_JSON=""
export VITE_APPLE_DEVELOPER_MERCHANTID_DOMAIN_ASSOCIATION=""

# Miscellaneous variables.
# Defaults derived from $(hostname)
# export VITE_API_URL="http://localhost:4001/v1/"
# export VITE_ORIGIN="https://localhost:3000"
export VITE_APP_BUNDLE_ID="zone.homie.flirtual.pwa"
export VITE_PICO_APP_ID=7aa1002e9d57599bb810a2b57c99db06
export REACT_EDITOR=code

# Runtime worker variables.
export BASE_ORIGIN="https://$(hostname):3000"
export API_URL="https://$(hostname):4001/v1/"
export BUCKET_UPLOADS_ORIGIN=""
export IMAGE_ACCESS_TOKEN="local_lk8agDaGutgEWwTBssV2f1Y0bOctRAHa89AZgmjFUh462F0N32tPwTjtynG"
