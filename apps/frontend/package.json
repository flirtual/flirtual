{
	"type": "module",
	"packageManager": "pnpm@10.16.1",
	"scripts": {
		"dev": "react-router dev",
		"typegen": "wrangler types --include-runtime false && react-router typegen",
		"typecheck:worker": "tsc -p src/worker/tsconfig.json",
		"build": "rm -rf .sonda && pnpm typegen && react-router build",
		"build:preview": "sh -c 'name=${1:-$(whoami)} && VITE_PREVIEW=\"$name\" pnpm -s build --mode=\"$name\"' --",
		"production": "pnpm -s build --mode=production && wrangler deploy --env=production --old-asset-ttl=7776000 -c ./dist/client/wrangler.json",
		"preview": "sh -c 'name=${1:-$(whoami)} && pnpm -s build:preview $name && wrangler versions upload --env=canary -c ./dist/client/wrangler.json --preview-alias=\"$name\"' --",
		"canary": "pnpm -s build:preview canary && wrangler deploy --env=canary --old-asset-ttl=7776000 -c ./dist/client/wrangler.json",
		"android:build": "cap sync android && cd ./android && ./gradlew build",
		"android:uninstall": "adb uninstall zone.homie.flirtual.pwa",
		"android:install": "adb install ./android/app/build/outputs/apk/debug/app-debug.apk",
		"clean": "rm -rf node_modules dist .react-router .sonda && pnpm install --force"
	},
